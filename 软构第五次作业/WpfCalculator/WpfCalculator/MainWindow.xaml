<Window x:Class="WpfCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCalculator"
        mc:Ignorable="d"
        Title="计算器" Height="450" Width="350" ResizeMode="NoResize">
    <Grid Margin="10">
        <!-- 定义两行：第一行放显示框，第二行放按钮网格 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 显示文本框 -->
        <TextBox x:Name="txtDisplay" Grid.Row="0" Height="60" Margin="0,0,0,10"
                 FontSize="24" TextAlignment="Right" IsReadOnly="True"
                 Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1"/>

        <!-- 按钮网格布局 -->
        <Grid Grid.Row="1" ShowGridLines="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 第一行按钮：7、8、9、÷ -->
            <Button Grid.Row="0" Grid.Column="0" Content="7" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="÷" Margin="5" FontSize="20" Click="OperButton_Click" Background="#FF9999"/>

            <!-- 第二行按钮：4、5、6、× -->
            <Button Grid.Row="1" Grid.Column="0" Content="4" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="×" Margin="5" FontSize="20" Click="OperButton_Click" Background="#FF9999"/>

            <!-- 第三行按钮：1、2、3、- -->
            <Button Grid.Row="2" Grid.Column="0" Content="1" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Margin="5" FontSize="20" Click="OperButton_Click" Background="#FF9999"/>

            <!-- 第四行按钮：0、C、=、+ -->
            <Button Grid.Row="3" Grid.Column="0" Content="0" Margin="5" FontSize="20" Click="NumButton_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="C" Margin="5" FontSize="20" Click="ClearButton_Click" Background="#FF6666"/>
            <Button Grid.Row="3" Grid.Column="2" Content="=" Margin="5" FontSize="20" Click="EqualButton_Click" Background="#99FF99"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Margin="5" FontSize="20" Click="OperButton_Click" Background="#FF9999"/>
        </Grid>
    </Grid>
</Window>